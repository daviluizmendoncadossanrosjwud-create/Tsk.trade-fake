                end
            end
            -- Fallback: teleport simples
            showNotif("🔄 Reconectando ao mesmo jogo...", Color3.fromRGB(255, 160, 50))
            task.wait(0.5)
            TeleportService:Teleport(PLACE_ID, LP)
        end)
    end)
