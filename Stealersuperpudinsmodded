-- Tenta carregar sessão salva do arquivo
local function loadSession()
    pcall(function()
        if isfile and isfile(KEY_SAVE_FILE) then
            local raw  = readfile(KEY_SAVE_FILE)
            local data = HttpService:JSONDecode(raw)
            if data and data.startTime and data.userId then
                local elapsed = os.time() - data.startTime
                -- Verifica se a key ainda está válida E é do mesmo usuário
