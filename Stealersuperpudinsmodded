-- Retorna tempo restante formatado
local function getTimeLeft()
    if not getgenv().PudimSession.valid then return "00:00:00" end
    local elapsed = os.time() - getgenv().PudimSession.startTime
    local left    = KEY_DURATION - elapsed
    if left <= 0 then
        getgenv().PudimSession.valid = false
        return "EXPIRADA"
    end
    local h = math.floor(left / 3600)
    local m = math.floor((left % 3600) / 60)
    local s = math.floor(left % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

