    task.spawn(function()
        pcall(function()
            local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(PLACE_ID)
            local ok, res = pcall(function()
                return HttpService:JSONDecode(game:HttpGet(url))
            end)
            if ok and res and res.data then
                local myJobId = game.JobId
                for _, server in ipairs(res.data) do
                    if server.id ~= myJobId and server.playing < server.maxPlayers then
                        showNotif("✅ Entrando em servidor novo!", Color3.fromRGB(100, 255, 100))
                        task.wait(0.8)
                        TeleportService:TeleportToPlaceInstance(PLACE_ID, server.id, LP)
