                    local n = obj.ActionText:lower() .. obj.ObjectText:lower()
                    if n:find("steal") or n:find("roubar") or n:find("grab") then
                        if not managedPrompts[obj] then
                            managedPrompts[obj] = true
                            fireproximityprompt(obj)
                        end
                    end
                end
            end
            -- Reseta cache a cada ciclo para re-ativar
            task.wait(0.5)
            managedPrompts = {}
        end)
    end
end)

