-- LÓGICA PRINCIPAL DE INICIALIZAÇÃO
-- ══════════════════════════════════════════════════════════
local function init()
    -- Verifica se a sessão já está válida (veio de server hop ou já logou)
    if getgenv().PudimSession.valid then
        local elapsed = os.time() - getgenv().PudimSession.startTime
        if elapsed < KEY_DURATION then
            -- Sessão válida: abre hub direto SEM pedir key
            showNotif("🍮 PudimSteal carregado! Key válida.", Color3.fromRGB(100, 255, 100))
            task.wait(0.5)
            openMainHub()
            return
        else
            -- Sessão expirou
            getgenv().PudimSession.valid = false
            pcall(function()
                if isfile and isfile(KEY_SAVE_FILE) then
                    delfile(KEY_SAVE_FILE)
                end
            end)
        end
    end
    -- Sem sessão válida: mostra key system
    openKeyGui()
end

