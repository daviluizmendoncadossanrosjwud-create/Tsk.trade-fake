		local n=tonumber(podium.Name)
		if not n then continue end
		if srcSlot and srcSlot.podNum==n then continue end
		local isServerOnly=sv[n] and not AllSlots[n]
		if isServerOnly then continue end
		local base=podium:FindFirstChild("Base")
		if not base then continue end
		local sp=base:FindFirstChild("Spawn")
		if not sp then continue end
		local pp=Instance.new("ProximityPrompt")
		pp.ActionText="Place"
		local grabbedName=(A_d and A_d[Grab.index] and A_d[Grab.index].DisplayName) or Grab.index
		pp.ObjectText=dispName(grabbedName,Grab.traits or {})
		pp.HoldDuration=1.5
		pp.KeyboardKeyCode=Enum.KeyCode.E
		pp.RequiresLineOfSight=true
		pp.MaxActivationDistance=10
		pp.Style=Enum.ProximityPromptStyle.Custom
		pp:SetAttribute("State","Place")
		pp.Parent=ppPar(sp)
		table.insert(PlacePrompts,pp)
		pp.Triggered:Connect(function()
			if not Grab.active then return end
			local src=Grab.sourceSlot
			if not src then return end
			if src.podNum==n then task.defer(cancelGrab,true); return end
			local dCF=sp:GetPivot()
			local dSlot=AllSlots[n]
			if dSlot then
				local srcOld=src.podNum
				local dstOld=dSlot.podNum
				local sSp=src.sp
				local sCF=sSp:GetPivot()
				local sN=srcOld
				dSlot.clone:PivotTo(sCF)
				dSlot.grabPr.Parent=ppPar(sSp)
				dSlot.sellPr.Parent=ppPar(sSp)
				AllSlots[dstOld]=nil
				dSlot.sp=sSp
				dSlot.podNum=sN
				AllSlots[sN]=dSlot
				_G.SpawnedAnimals[sN]={Index=dSlot.index,Mutation=dSlot.mutation,Traits=dSlot.traits,spawnPart=sSp}
				src.clone:PivotTo(dCF)
				src.grabPr.Parent=ppPar(sp)
				src.sellPr.Parent=ppPar(sp)
				AllSlots[srcOld]=nil
				src.sp=sp
				src.podNum=n
				AllSlots[n]=src
				_G.SpawnedAnimals[n]={Index=src.index,Mutation=src.mutation,Traits=src.traits,spawnPart=sp}
				setTransp(src.clone,nil)
				setOHFull(src.gui,src.data,src.mutation)
				src.grabbed=false
				src.grabPr.ActionText="Grab"
				src.grabPr:SetAttribute("State","Grab")
				src.sellPr.Enabled=true
				local trove=Trove.new()
				local _,_,newCl=createVis(trove,src.index,src.mutation,src.traits,workspace)
				if newCl then
					newCl:PivotTo(src.clone:GetPivot())
					local oldT=src.trove
					src.clone:Destroy()
					src.clone=newCl
					src.trove=trove
					playIdle(trove,src.gui,src.index)
					task.delay(0.1,function() oldT:Destroy() end)
				end
				local padSrc=activePads[srcOld]
				local padDst=activePads[dstOld]
				activePads[srcOld]=nil
				activePads[dstOld]=nil
				if padSrc then
					local nc=getClaimMain(plot,n)
					if nc and padSrc.bb then padSrc.bb.Parent=nc end
					padSrc.podiumNum=n
					activePads[n]=padSrc
				end
				if padDst then
					local nc=getClaimMain(plot,sN)
					if nc and padDst.bb then padDst.bb.Parent=nc end
					padDst.podiumNum=sN
					activePads[sN]=padDst
				end
			else
				src.clone:PivotTo(dCF)
				setTransp(src.clone,nil)
				setOHFull(src.gui,src.data,src.mutation)
				src.grabPr.Parent=ppPar(sp)
				src.sellPr.Parent=ppPar(sp)
				local oldPod=src.podNum
				_G.SpawnedAnimals[src.podNum]=nil
				AllSlots[src.podNum]=nil
				src.sp=sp
				src.podNum=n
				AllSlots[n]=src
				_G.SpawnedAnimals[n]={Index=src.index,Mutation=src.mutation,Traits=src.traits,spawnPart=sp}
				src.grabbed=false
				src.grabPr.ActionText="Grab"
				src.grabPr:SetAttribute("State","Grab")
				src.sellPr.Enabled=true
				local trove=Trove.new()
				local _,_,newCl=createVis(trove,src.index,src.mutation,src.traits,workspace)
				if newCl then
					newCl:PivotTo(src.clone:GetPivot())
					local oldT=src.trove
					src.clone:Destroy()
					src.clone=newCl
					src.trove=trove
					playIdle(trove,src.gui,src.index)
					task.delay(0.1,function() oldT:Destroy() end)
				end
				local padSrc2=activePads[oldPod]
				if padSrc2 then
					local nc=getClaimMain(plot,n)
					if nc and padSrc2.bb then padSrc2.bb.Parent=nc end
					padSrc2.podiumNum=n
					activePads[n]=padSrc2
					activePads[oldPod]=nil
				end
			end
			saveData()
			task.defer(cancelGrab,false)
		end)
	end
end

local SpawnStatus

local function doSpawn(plot,idx,mut,traits,spawnedAt)
	if not Trove then
		if SpawnStatus then SpawnStatus.Text="Trove unavailable"; SpawnStatus.TextColor3=Color3.fromRGB(255,100,100) end
		return
	end
	local slots=getFreeSlots(plot)
	if #slots==0 then
		if SpawnStatus then SpawnStatus.Text="No free slots!"; SpawnStatus.TextColor3=Color3.fromRGB(255,100,100) end
		return
	end
	local slot=slots[1]
	local sp=getSpawnPart(plot,slot)
	if not sp then
		if SpawnStatus then SpawnStatus.Text="Spawn #"..slot.." not found"; SpawnStatus.TextColor3=Color3.fromRGB(255,100,100) end
		return
	end
	local podCF=sp:GetPivot()
	local data=A_d and A_d[idx]
	local trove=Trove.new()
	local _,anim,cl=createVis(trove,idx,mut,traits,workspace)
	if not cl then
		trove:Destroy()
		if SpawnStatus then SpawnStatus.Text="Animal not found: "..idx; SpawnStatus.TextColor3=Color3.fromRGB(255,100,100) end
		return
	end
	local extents=cl:GetExtentsSize()
	cl:PivotTo(podCF)
	playIdle(trove,anim,idx)
	local fullGui,_=createOH(trove,cl,sp,idx,extents,mut,traits)
	local sellVal=(A_sh and A_sh.GetSellValue) and A_sh:GetSellValue(idx) or 0
	local ppBase=ppPar(sp)
	local grabPr=trove:Add(Instance.new("ProximityPrompt"))
	grabPr.ActionText="Grab"
	local bn=(data and data.DisplayName) or idx
	grabPr.ObjectText=dispName(bn,traits or {})
	grabPr.HoldDuration=1.5
	grabPr.KeyboardKeyCode=Enum.KeyCode.E
	grabPr.RequiresLineOfSight=true
	grabPr.MaxActivationDistance=10
	grabPr.Style=Enum.ProximityPromptStyle.Custom
	grabPr:SetAttribute("State","Grab")
	grabPr.Parent=ppBase
	local sellPr=trove:Add(Instance.new("ProximityPrompt"))
	sellPr.ActionText="Sell: "..fmt(sellVal)
	sellPr.ObjectText=""
	sellPr.HoldDuration=1.5
	sellPr.KeyboardKeyCode=Enum.KeyCode.F
	sellPr.RequiresLineOfSight=true
	sellPr.MaxActivationDistance=10
	sellPr.Style=Enum.ProximityPromptStyle.Custom
	sellPr.UIOffset=Vector2.new(0,-72)
	sellPr:SetAttribute("State","Sell")
	sellPr.Parent=ppBase
	local slotInfo={
		podNum=slot,sp=sp,clone=cl,gui=fullGui,
		grabPr=grabPr,sellPr=sellPr,data=data,index=idx,
		mutation=mut,traits=traits,trove=trove,grabbed=false,
		spawnedAt=spawnedAt or os.clock(),
	}
	AllSlots[slot]=slotInfo
	_G.SpawnedAnimals[slot]={Index=idx,Mutation=mut,Traits=traits,spawnPart=sp}
	invalCache()
	grabPr.Triggered:Connect(function()
		if slotInfo.grabbed then
			if Grab.sourceSlot==slotInfo then cancelGrab(true) end
			return
		end
		if slotInfo.grabbed then task.defer(cancelGrab,false); return end
		if Grab.active then cancelGrab(false) end
		slotInfo.grabbed=true
		grabPr.ActionText="Drop"
		grabPr:SetAttribute("State","Drop")
		sellPr.Enabled=false
		setTransp(cl,0.5)
		local gps=0
		if A_sh and NumU then
			local o,g=pcall(function() return A_sh:GetGeneration(idx,mut,traits) end)
			if o then gps=g or 0 end
		end
		setOHGrab(fullGui,mut,gps)
		LP:SetAttribute("Stealing",true)
		setSpd(SPD_G)
		local ht=Trove.new()
		Grab.handTrove=ht
		Grab.active=true
		Grab.index=idx
		Grab.mutation=mut
		Grab.traits=traits
		Grab.sourceSlot=slotInfo
		spawnHand(ht,idx,mut,traits)
		playHold(ht)
		showPPs(plot,slotInfo)
	end)
	sellPr.Triggered:Connect(function()
		if Grab.active and Grab.sourceSlot==slotInfo then cancelGrab(false) end
		local pNum=slotInfo.podNum
		AllSlots[pNum]=nil
		if _G.SpawnedAnimals then _G.SpawnedAnimals[pNum]=nil end
		invalCache()
		saveData()
		trove:Destroy()
	end)
	trove:Add(function()
		AllSlots[slotInfo.podNum]=nil
		_G.SpawnedAnimals[slotInfo.podNum]=nil
		if Grab.sourceSlot==slotInfo then cancelGrab(false) end
		removePad(slotInfo.podNum)
	end)
	local realScale=cl:GetScale()
	cl:ScaleTo(0.001)
	cl:PivotTo(podCF)
	local nv=trove:Add(Instance.new("NumberValue"))
	nv.Value=0.001
	trove:Add(nv.Changed:Connect(function(v) cl:ScaleTo(v); cl:PivotTo(podCF) end))
	local tw=TW:Create(nv,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Value=realScale})
	tw:Play()
	tw.Completed:Wait()
	nv.Value=realScale
	if SpawnStatus then SpawnStatus.Text="OK: "..idx.." (slot "..slot..")"; SpawnStatus.TextColor3=Color3.fromRGB(57,204,24) end
	monGUI(idx)
	saveData()
	task.spawn(function()
		task.wait(0.3)
		local cm=getClaimMain(plot,slot)
		if cm then buildCashPad(cm,idx,mut,traits,slot,spawnedAt) end
	end)
end

local function delAll()
	for s,inf in pairs(AllSlots) do
		if inf.trove then pcall(function() inf.trove:Destroy() end) end
	end
	AllSlots={}
	_G.SpawnedAnimals={}
	invalCache()
	saveData()
	if SpawnStatus then SpawnStatus.Text="All spawned brainrots removed"; SpawnStatus.TextColor3=Color3.fromRGB(57,204,24) end
	task.delay(2,function() if SpawnStatus then SpawnStatus.Text="" end end)
end

task.spawn(function()
	task.wait(3)
	local saved=loadSave()
	if not saved then return end
	local plot
	local tries=0
	repeat
		plot=getPlot()
		if not plot then task.wait(1) end
		tries=tries+1
	until plot or tries>20
	if not plot then return end
	for s,inf in pairs(saved) do
		if inf.index and inf.index~="" then
			if slotOcc(s) then continue end
			local tr=inf.traits
			if type(tr)=="string" and tr~="" then
				local t={}
				for p in tr:gmatch("[^,]+") do table.insert(t,p) end
				tr=#t>0 and t or nil
			elseif type(tr)~="table" then tr=nil end
			if type(tr)=="table" and #tr==0 then tr=nil end
			local mut=(inf.mutation and inf.mutation~="") and inf.mutation or nil
			doSpawn(plot,inf.index,mut,tr,inf.spawnedAt)
			task.wait(0.15)
		end
	end
end)

