local SUF={{1e18,"Qi"},{1e15,"Qa"},{1e12,"T"},{1e9,"B"},{1e6,"M"},{1e3,"K"}}
local function fmt(n)
	if NumU then
		local o,r=pcall(function() return NumU:ToString(n) end)
		if o and r then return "$"..r end
	end
	if not n then return "$0" end
	for _,p in ipairs(SUF) do
		local d,s=p[1],p[2]
		if math.abs(n)>=d then
			local v=n/d
			if v<100 then return string.format("$%.1f%s",v,s)
			else return string.format("$%.0f%s",v,s) end
		end
	end
	return string.format("$%.0f",n)
end
local function fmt1(n)
	if not n or n==0 then return "$0" end
	if NumU then
		local o,r=pcall(function() return NumU:ToString(n,1) end)
		if o and r then return "$"..r end
	end
	local s2={{1e24,"Tvg"},{1e21,"Dvg"},{1e18,"Qi"},{1e15,"Qa"},{1e12,"T"},{1e9,"B"},{1e6,"M"},{1e3,"K"}}
	for _,p in ipairs(s2) do
		local d,s=p[1],p[2]
		if math.abs(n)>=d then
			local v=n/d
			local fl=math.floor(v*10)/10
			local str=string.format("%.1f",fl):gsub("%.0$","")
			return "$"..str..s
		end
	end
	return "$"..math.floor(n)
end

