local function startCount5(onComp)
	if activeCountdown then activeCountdown:Disconnect(); activeCountdown=nil end
	countdownActive=true
	updReadyColor()
	local rem=5
	if timerL then timerL.Text=EMO_B..string.format("%.1f",rem).."s Left" end
	activeCountdown=RS.Heartbeat:Connect(function(dt)
		if myAcc and otherAcc then
			activeCountdown:Disconnect()
			activeCountdown=nil
			countdownActive=false
			if timerL then timerL.Text="" end
			updReadyColor()
			checkComplete()
			return
		end
		rem=rem-dt
		if timerL then timerL.Text=EMO_B..string.format("%.1f",math.max(rem,0)).."s Left" end
		if rem<=0 then
			activeCountdown:Disconnect()
			activeCountdown=nil
			countdownActive=false
			if timerL then timerL.Text="" end
			updReadyColor()
			if onComp then onComp() end
		end
	end)
end

local function resetTimer()
	if accPhase then startCount5(checkComplete) else startCount5(nil) end
end

local function updSlotTexts()
