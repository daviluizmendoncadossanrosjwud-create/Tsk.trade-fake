local vpClean={}
local function setupVP(vp,idx,mut)
	if vpClean[vp] then pcall(vpClean[vp]); vpClean[vp]=nil end
	vp:ClearAllChildren()
	if A_sh and A_sh.AttachOnViewportWithOptimizations then
		local o,cl=pcall(function() return A_sh:AttachOnViewportWithOptimizations(idx,vp,nil,mut) end)
		if o and cl then vpClean[vp]=cl; return end
	end
	if not ModA then return end
	local tmp=ModA:FindFirstChild(idx)
	if not tmp then return end
	local cam=Instance.new("Camera")
	cam.Name="Camera"
	cam.Parent=vp
	vp.CurrentCamera=cam
	local wm=Instance.new("WorldModel")
	wm.Name="WorldModel"
	wm.Parent=vp
	local cl=tmp:Clone()
	for _,v in cl:GetDescendants() do
		if v:IsA("Script") or v:IsA("LocalScript") then v:Destroy() end
		if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then v:Destroy() end
	end
	cl.Parent=wm
	task.spawn(function()
		task.wait(0.05)
		local o2,cf,sz=pcall(function() return cl:GetBoundingBox() end)
		if not o2 or not cf then
			local pp=cl.PrimaryPart or cl:FindFirstChildOfClass("BasePart")
			if not pp then return end
			cf=pp.CFrame
			sz=pp.Size
		end
		for _,v in cl:GetDescendants() do if v:IsA("BasePart") then v.Anchored=true end end
		local d=math.max(sz.X,sz.Y,sz.Z)*1.6
		cam.CFrame=CFrame.new(cf.Position+Vector3.new(0,sz.Y*0.1,d))*CFrame.Angles(0,math.pi,0)
		cam.Focus=CFrame.new(cf.Position+Vector3.new(0,sz.Y*0.1,0))
	end)
end

local function buildTraits(fr,names)
	for _,ch in fr:GetChildren() do if not ch:IsA("UIListLayout") then ch:Destroy() end end
	if not names or #names==0 then return end
	local rows={}
	local cur={}
	for i,n in ipairs(names) do
		table.insert(cur,n)
		if #cur==6 or i==#names then
			table.insert(rows,cur)
			cur={}
		end
	end
	for ri,row in ipairs(rows) do
		local rfr=ni("Frame",{BackgroundTransparency=1,BorderSizePixel=0,Size=UDim2.new(1,0,1/#rows,0),LayoutOrder=ri},fr)
		ni("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,HorizontalAlignment=Enum.HorizontalAlignment.Center,VerticalAlignment=Enum.VerticalAlignment.Center,SortOrder=Enum.SortOrder.LayoutOrder},rfr)
		for ci,tname in ipairs(row) do
			local td=T_d and T_d[tname]
			if td and td.Icon then
				ni("ImageLabel",{Name=tname,BackgroundTransparency=1,BorderSizePixel=0,Image=td.Icon,ScaleType=Enum.ScaleType.Fit,Size=UDim2.new(1/6,0,1,0),ZIndex=10,LayoutOrder=ci},rfr)
			end
		end
	end
end

