		gui.Rarity.TextColor3=rar.Color
		if rar.StrokeColor then
			local rst=gui.Rarity:FindFirstChildOfClass("UIStroke")
			if rst then rst.Color=rar.StrokeColor end
		end
		if rar.GradientPreset and Grad then trove:Add(Grad.apply(gui.Rarity,rar.GradientPreset)) end
	end
	gui.Mutation.Visible=mut~=nil
	if mut and M_d then
		local m=M_d[mut]
		if m then
			gui.Mutation.RichText=m.UseRichText or false
			gui.Mutation.Text=m.UseRichText and m.DisplayWithRichText or m.DisplayText
			if m.GradientPreset and Grad then trove:Add(Grad.apply(gui.Mutation,m.GradientPreset))
			elseif m.MainColor then gui.Mutation.TextColor3=m.MainColor end
		end
	end
	if traits and #traits>0 and T_d then
		local tmp=gui.Traits:FindFirstChild("Template")
		if tmp then
