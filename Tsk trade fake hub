function TradeUI.StartTrade(oid)
	buildUI()
	curMyInv=buildInv()
	selSlots={}
	confSlots={}
	myReady=false
	otherReady=false
	myAcc=false
	otherAcc=false
	tradeOpen=true
	accPhase=false
	proc=false
	lastClick=0
	countdownActive=false
	otherName="Other"
	signLast=tick()-signDelay
	stopCount()
	populateCards(yourSc,curMyInv,true)
	populateOther()
	updSlotTexts()
	if oid then
		local o,nm=pcall(function() return P:GetNameFromUserIdAsync(oid) end)
		if o then
			otherName=nm
			local ou=mainFr:FindFirstChild("Other") and mainFr.Other:FindFirstChild("Username")
			if ou then ou.Text="@"..nm.."'s Offer" end
			local osn2=otherSign:FindFirstChild("Username")
			local osi2=otherSign:FindFirstChild("PlayerImage")
			if osn2 then osn2.Text="@"..nm end
			if osi2 then osi2.Image="rbxthumb://type=AvatarHeadShot&id="..oid.."&w=100&h=100" end
		end
		local oh=mainFr:FindFirstChild("Other") and mainFr.Other:FindFirstChild("PlayerImage")
		if oh then oh.Image="rbxthumb://type=AvatarHeadShot&id="..(oid or 0).."&w=100&h=100" end
	end
	readyFr.Visible=false
	readyFr2.Visible=false
	readyBtn.BackgroundColor3=Color3.fromRGB(112,112,112)
	readyBtn.Txt.Text="READY"
	timerL.Text=""
	signTB.Text="Sign"
	otherSignTxt.Text="Sign"
	hideUI(true)
	tradeGui.Enabled=true
	mainFr.Visible=true
	mainFr.Position=UDim2.new(0.5,0,-1.5,0)
	local t=TW:Create(mainFr,TweenInfo.new(0.2,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Position=UDim2.new(0.5,0,0.5,0)})
	t:Play()
	t.Completed:Connect(function()
		if tradeOpen then startCount5(nil) end
	end)
end

function TradeUI.MyReady()
	if not tradeOpen then return end
	if countdownActive then return end
	if not accPhase then
		if not hasSel() then return end
		if myReady then return end
		myReady=true
		confSlots={}
		for s in pairs(selSlots) do confSlots[s]=true end
		updReadyColor()
		readyFr.Visible=true
		readyFr.Label.Text="Ready!"
		if otherReady then
			accPhase=true
			readyBtn.Txt.Text="ACCEPT"
			readyFr.Visible=false
			readyFr2.Visible=false
			updReadyColor()
			populateConfirmed()
			populateOther()
			resetTimer()
		else
			resetTimer()
		end
	else
		if myAcc then return end
		myAcc=true
		updReadyColor()
		readyFr.Visible=true
		readyFr.Label.Text="Confirmed!"
		if myAcc and otherAcc then
			stopCount()
			checkComplete()
		else
			resetTimer()
		end
	end
end

function TradeUI.OtherPlayerContinue()
	if not tradeOpen then return end
	if countdownActive then return end
	if not accPhase then
		otherReady=true
		readyFr2.Visible=true
		readyFr2.Label.Text="Ready!"
		if myReady then
			accPhase=true
			readyBtn.Txt.Text="ACCEPT"
			readyFr.Visible=false
			readyFr2.Visible=false
			updReadyColor()
			populateConfirmed()
			populateOther()
			resetTimer()
		else
			resetTimer()
		end
	else
		if otherAcc then return end
		otherAcc=true
		readyFr2.Visible=true
		readyFr2.Label.Text="Confirmed!"
		if myAcc and otherAcc then
			stopCount()
			checkComplete()
		else
			resetTimer()
		end
	end
end

function TradeUI.AddOtherPlayerSignMsg(msg)
	if not tradeOpen then return end
	if otherSignTxt then otherSignTxt.Text=msg or "Sign" end
end

function TradeUI.MyPlayerCancel()
	if not tradeOpen then return end
	if Notif then pcall(function() Notif:Error("@"..LP.Name.." canceled") end) end
	closeTrade()
end

function TradeUI.OtherPlayerCancel()
	if not tradeOpen then return end
	if Notif then pcall(function() Notif:Error("@"..otherName.." canceled") end) end
	closeTrade()
end

local function fireClose()
	local o,g=pcall(function() return PG:WaitForChild("TradePlayerList",1) end)
	if not o or not g then return end
