local function buildCashPad(claimMain,idx,mut,traits,podNum,spawnedAt)
	if activePads[podNum] then
		if activePads[podNum].thread then task.cancel(activePads[podNum].thread) end
		if activePads[podNum].cleanup then pcall(activePads[podNum].cleanup) end
		if activePads[podNum].bb and activePads[podNum].bb.Parent then activePads[podNum].bb:Destroy() end
		activePads[podNum]=nil
	end
	local att=Instance.new("Attachment")
	att.Name="CashPadAttachment"
	att.CFrame=CFrame.new(0,PAD_H,0)
	att.Parent=claimMain
	local lblAmt,lblOff,cleanFn
	local bb
	local isNew=(spawnedAt==nil)
	if FOH and FOH.createFastOverhead and FOH.GuiTemplates and FOH.GuiTemplates.CashPad then
		local o,res,cl=pcall(function() return FOH.createFastOverhead({adornee=att,guiTemplate=FOH.GuiTemplates.CashPad}) end)
		if o and res then
			bb=res
			cleanFn=cl
			lblAmt=bb:FindFirstChild("CollectAmount",true)
			lblOff=bb:FindFirstChild("Offline",true)
			if lblOff then
				if isNew then lblOff.Visible=false
				else
					local gen=getGen(idx,mut,traits)
					local now=os.clock()
					local elapsed=now-(spawnedAt or now)
					local offAmt=math.floor(elapsed)*gen
					if offAmt>0 then
						lblOff.RichText=true
						lblOff.Text=string.format("(Offline Cash: <font color=\"#73ff00\">%s</font>)",fmt1(offAmt))
						lblOff.Visible=true
					else lblOff.Visible=false end
				end
			end
		end
	end
	if not bb then
		bb=Instance.new("BillboardGui")
		bb.Name="CashPad_BB"
		bb.Active=true
		bb.AlwaysOnTop=false
		bb.Size=UDim2.new(0,220,0,80)
		bb.StudsOffsetWorldSpace=Vector3.new(0,PAD_H,0)
		bb.MaxDistance=30
		bb.ZIndexBehavior=Enum.ZIndexBehavior.Global
		bb.DisplayOrder=100
		bb.Adornee=att
		bb.Parent=att
		local ll=Instance.new("UIListLayout",bb)
		ll.FillDirection=Enum.FillDirection.Vertical
		ll.HorizontalAlignment=Enum.HorizontalAlignment.Center
		ll.VerticalAlignment=Enum.VerticalAlignment.Center
		ll.SortOrder=Enum.SortOrder.LayoutOrder
		local function mkL(nm,ord,sy,col,txt)
			local l=Instance.new("TextLabel",bb)
			l.Name=nm; l.Size=UDim2.new(1,0,sy,0)
			l.BackgroundTransparency=1; l.TextScaled=true
			l.FontFace=FNT; l.TextColor3=col
			l.Text=txt; l.LayoutOrder=ord
			local s=Instance.new("UIStroke",l)
			s.Thickness=1; s.Color=Color3.new(0,0,0)
			return l
		end
		mkL("Collect",1,0.3,Color3.fromRGB(202,255,201),"Coletar")
		lblAmt=mkL("CollectAmount",2,0.4,Color3.fromRGB(115,255,0),"$0")
		lblOff=mkL("Offline",3,0.3,Color3.fromRGB(180,255,100),"")
		if isNew then lblOff.Visible=false
		else
			local gen=getGen(idx,mut,traits)
			local now=os.clock()
			local elapsed=now-(spawnedAt or now)
			local offAmt=math.floor(elapsed)*gen
			if offAmt>0 then
				lblOff.RichText=true
				lblOff.Text=string.format("(Offline Cash: <font color=\"#73ff00\">%s</font>)",fmt1(offAmt))
				lblOff.Visible=true
			else lblOff.Visible=false end
		end
	end
	activePads[podNum]={bb=att,thread=nil,cleanup=cleanFn,podiumNum=podNum,lastCollect=os.clock()}
	local pad=activePads[podNum]
	do
		local deb=false
		local conn
		conn=RS.Heartbeat:Connect(function()
			if not (pad.bb and pad.bb.Parent) then conn:Disconnect(); return end
			if deb then return end
			local char=LP.Character
			if not char then return end
			local hrp=char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
			local curClaim=pad.bb.Parent
			if not curClaim or not curClaim:IsA("BasePart") then return end
			local dist=(hrp.Position-curClaim.Position).Magnitude
			if dist<=6 then
				deb=true
				local curAmt=lblAmt and lblAmt.Parent and lblAmt.Text or "$0"
				if curAmt~="$0" and curAmt~="" then pcall(showMoneyNotif,curAmt) end
				pad.lastCollect=os.clock()
				if lblAmt and lblAmt.Parent then lblAmt.Text="$0" end
				if lblOff and lblOff.Parent then lblOff.Visible=false end
				task.delay(1,function() deb=false end)
			end
		end)
	end
	local thr=task.spawn(function()
		while pad.bb and pad.bb.Parent do
			task.wait(1)
			if not (pad.bb and pad.bb.Parent) then break end
			local gen=getGen(idx,mut,traits)
			local elapsed=os.clock()-(pad.lastCollect or os.clock())
			local amt=math.floor(elapsed)*gen
			if lblAmt and lblAmt.Parent then lblAmt.Text=fmt1(amt) end
		end
	end)
	pad.thread=thr
	return pad.bb
end

