	local sc=0 for _ in pairs(selSlots) do sc=sc+1 end
	local ic=0 for _ in pairs(curMyInv) do ic=ic+1 end
	local rem=ic-sc
	baseSlots1.Text=rem.."/"..(customMySlots or 27)
	baseSlots2.Text=sc.."/"..(customOtherSlots or 23)
end

local function clearScroll(sc)
	for _,ch in sc:GetChildren() do if ch:IsA("Frame") then ch:Destroy() end end
	cardSel={}
end

local function populateCards(sc,inv,click)
	clearScroll(sc)
	local slots={}
	for s,data in pairs(inv) do
		local can=click and not data._isServer
		table.insert(slots,{slot=s,data=data,can=can})
	end
	table.sort(slots,function(a,b) return a.slot<b.slot end)
	for _,ent in ipairs(slots) do
		local name=ent.data.DisplayName or tostring(ent.slot)
		local midx=ent.data.OriginalIndex or ent.data.DisplayName
		local cash=ent.data.Cash or ""
		local traits=ent.data.Traits or {}
		local mut=ent.data.Mutation or ""
		local bg,st=nil,nil
		if A_d and A_d[name] and A_d[name].IsSecret then
			bg=Color3.fromRGB(15,50,15)
			st=Color3.fromRGB(0,255,0)
		end
		local function onToggle(s,isOn)
			if not tradeOpen or accPhase or ent.data._isServer then return end
			playSnd()
			if isOn then
				local now=tick()
				if now-lastClick<clickDelay then
					if Notif then pcall(function() Notif:Error("Please wait before adding another brainrot") end) end
					local fn=cardSel[s]
					if fn then fn(false) end
					return
				end
				lastClick=now
				selSlots[s]=true
			else
				selSlots[s]=nil
				if myReady then
					myReady=false
					otherReady=false
					otherAcc=false
					if readyBtn then readyBtn.Txt.Text="READY" end
					if readyFr then readyFr.Visible=false end
					if readyFr2 then readyFr2.Visible=false end
				end
			end
			updReadyColor()
			updSlotTexts()
			resetTimer()
		end
		local _,_,setFn=createCard(sc,name,cash,traits,ent.slot,mut,bg,st,ent.can,onToggle,midx)
		if ent.can then cardSel[ent.slot]=setFn end
	end
end

