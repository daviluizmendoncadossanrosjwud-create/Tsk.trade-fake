		elseif k==currKeys.HideAllGuis then Main.Visible=not Main.Visible; Holder.Active=Main.Visible end
	end)
	local function parseTraits(s)
		local t={}
		for p in s:gmatch("[^,]+") do
			local r=p:match("^%s*(.-)%s*$")
			if r~="" then table.insert(t,r) end
		end
		return t
	end
	spawnBtn.MouseButton1Click:Connect(function()
		local anName=animalBox and animalBox.Text:match("^%s*(.-)%s*$") or ""
		if anName=="" then
			SpawnStatus.Text="Enter an animal name"
			SpawnStatus.TextColor3=Color3.fromRGB(255,200,80)
			return
		end
		local idx=anName
		if A_d then
			for id,data in pairs(A_d) do
				if (data.DisplayName or ""):lower()==anName:lower() or id:lower()==anName:lower() then
					idx=id
					break
				end
			end
		end
		local mut=mutBox and mutBox.Text:match("^%s*(.-)%s*$") or ""
		mut=mut~="" and mut or nil
		local traitsRaw=traitBox and traitBox.Text:match("^%s*(.-)%s*$") or ""
		local traits=traitsRaw~="" and parseTraits(traitsRaw) or nil
		SpawnStatus.Text="Spawning..."
		SpawnStatus.TextColor3=Color3.fromRGB(255,200,80)
		task.spawn(function()
			local plot
			local tries=0
			repeat
				plot=getPlot()
				if not plot then task.wait(1) end
				tries=tries+1
			until plot or tries>15
			if not plot then
				SpawnStatus.Text="Plot not found"
				SpawnStatus.TextColor3=Color3.fromRGB(255,100,100)
				return
			end
			doSpawn(plot,idx,mut,traits)
		end)
	end)
end

task.spawn(function()
	local c=LP.Character or LP.CharacterAdded:Wait()
	local h=c:WaitForChild("Humanoid",5)
	if h then h.WalkSpeed=SPD_N end
end)
