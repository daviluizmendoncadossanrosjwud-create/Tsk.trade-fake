local function getTopY(cl,prim)
	local topY=-math.huge
	for _,v in cl:GetDescendants() do
		if v:IsA("BasePart") and v.Transparency<0.9 and v.Size.Magnitude>0.1 then
			local ty=v.Position.Y+v.Size.Y*0.3
			if ty>topY then topY=ty end
		end
	end
	if topY==-math.huge then return prim.Position.Y+prim.Size.Y*0.3 end
	return topY
end

